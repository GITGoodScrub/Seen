# Set this to your reachable backend host (LAN IP for physical devices).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Optional comma-separated fallbacks used automatically when the primary host fails.
EXPO_PUBLIC_API_BASE_URL_FALLBACKS=http://127.0.0.1:3000,http://10.0.2.2:3000

# Firebase client config used for email/password and Google auth in the mobile app.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth client IDs from Firebase project settings.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Temporary local bypass to access app screens without Firebase credentials.
# Set to true only for development, and set back to false before normal auth testing.
EXPO_PUBLIC_DEV_AUTH_BYPASS=false
